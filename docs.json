{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FyberPay Docs",
  "colors": {
    "primary": "#0d9488",
    "light": "#14b8a6",
    "dark": "#0f766e"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/introduction",
              "getting-started/quickstart",
              "getting-started/concepts"
            ]
          },
          {
            "group": "Platform Guides",
            "pages": [
              "guides/billing-setup",
              "guides/mpesa-integration",
              "guides/subscriber-management",
              "guides/network-provisioning",
              "guides/hotspot-setup",
              "guides/dunning-automation"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Hardware & Network",
            "pages": [
              "integrations/mikrotik",
              "integrations/freeradius",
              "integrations/genieacs"
            ]
          },
          {
            "group": "Payments",
            "pages": [
              "integrations/mpesa-daraja"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://fyberpay.com/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@fyberpay.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://fyberpay.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Blog",
        "href": "https://fyberpay.com/blog"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://fyberpay.com/register"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/fyberpay",
      "github": "https://github.com/fyberpay",
      "linkedin": "https://linkedin.com/company/fyberpay"
    }
  }
}
